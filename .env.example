# Copy to .env if you want to override defaults. docker-compose reads these.
OLLAMA_BASE_URL=http://ollama:11434
CHROMA_HOST=chroma
CHROMA_PORT=8000
LLM_MODEL=llama3.1:8b
EMBED_MODEL=nomic-embed-text
CHROMA_COLLECTION=iam_docs
DATA_DIR=/data
# Optional LangSmith
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=
# LANGCHAIN_PROJECT=terraform-aws-rag
